.game-canvas {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  pointer-events: none;
}

.controls {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 180px;
  z-index: 100;
  display: flex;
  justify-content: center;
  align-items: center;
}

.roll-btn {
  width: 120px;
  height: 120px;
  padding: 0;
  margin: 0;
  border: none;
  border-radius: 60px;
  background: linear-gradient(145deg, #4a4a4a, #292929);
  box-shadow: 0 10px 24px rgba(0, 0, 0, 0.48), inset 0 2px 5px rgba(255, 255, 255, 0.12), inset 0 -7px 12px rgba(0, 0, 0, 0.28);
  position: relative;
}

.roll-btn::after {
  display: none;
}

.roll-btn .btn-inner {
  position: absolute;
  top: 6px;
  left: 6px;
  right: 6px;
  bottom: 6px;
  border-radius: 54px;
  background: linear-gradient(145deg, #5d5d5d, #363636);
  box-shadow: inset 0 2px 2px rgba(255, 255, 255, 0.22), inset 0 -5px 8px rgba(0, 0, 0, 0.22);
}

.roll-btn:active {
  transform: scale(0.95);
}

.roll-btn.rolling {
  opacity: 0.66;
}

.roll-text {
  position: relative;
  z-index: 2;
  font-size: 48px;
  font-weight: 700;
  color: #d4af37;
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.55), 0 0 18px rgba(212, 175, 55, 0.22);
}

.settings-btn {
  position: absolute;
  right: 30px;
  bottom: 50px;
  width: 48px;
  height: 48px;
  padding: 0;
  margin: 0;
  border: 1px solid rgba(255, 255, 255, 0.14);
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.12);
  box-shadow: 0 8px 22px rgba(0, 0, 0, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-btn::after {
  display: none;
}

.settings-btn-inner {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-icon {
  width: 30px;
  height: 30px;
  opacity: 0.88;
  display: block;
}

.settings-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 40;
  display: flex;
  justify-content: center;
  align-items: center;
  background: rgba(0, 0, 0, 0.6);
  opacity: 0;
  pointer-events: none;
}

.settings-modal.active {
  opacity: 1;
  pointer-events: auto;
}

.modal-content {
  width: 84%;
  max-width: 320px;
  padding: 30px 24px 24px;
  border-radius: 20px;
  background: rgba(30, 40, 30, 0.92);
  border: 1px solid rgba(255, 255, 255, 0.12);
  box-shadow: 0 18px 40px rgba(0, 0, 0, 0.34);
}

.modal-title {
  display: block;
  margin-bottom: 22px;
  color: #ffffff;
  text-align: center;
  font-size: 20px;
  font-weight: 600;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.setting-item:last-of-type {
  border-bottom: none;
}

.setting-label {
  color: rgba(255, 255, 255, 0.9);
  font-size: 16px;
}

.dice-count-control {
  display: flex;
  align-items: center;
  gap: 16px;
}

.count-btn {
  width: 36px;
  height: 36px;
  padding: 0;
  margin: 0;
  border: none;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.14);
  color: #ffffff;
  font-size: 20px;
  line-height: 36px;
}

.count-btn::after {
  display: none;
}

.count-value {
  min-width: 26px;
  color: #39ff14;
  font-size: 24px;
  font-weight: 700;
  text-align: center;
  text-shadow: 0 0 10px rgba(57, 255, 20, 0.32);
}

.close-btn {
  width: 100%;
  margin-top: 18px;
  padding: 12px 0;
  border: none;
  border-radius: 12px;
  background: linear-gradient(145deg, #4a4a4a, #343434);
  color: #ffffff;
  font-size: 15px;
  box-shadow: inset 0 1px 2px rgba(255, 255, 255, 0.14);
}

.close-btn::after {
  display: none;
}
